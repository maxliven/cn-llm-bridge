# ============================================================
# cn-llm-bridge 环境变量配置
# 复制此文件为 .env 并填入你的 API Key
# ============================================================

# ----- 阿里百炼（必填 — 视觉 + 云端转写）-----
# 获取地址: https://bailian.console.aliyun.com/
QWEN_API_KEY=sk-your-key-here
BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ----- Kimi / Moonshot（可选 — 深度合成）-----
# 获取地址: https://platform.moonshot.cn/
KIMI_API_KEY=sk-your-key-here
KIMI_BASE_URL=https://api.moonshot.cn/v1

# ----- faster-whisper 本地转写（可选）-----
# 模型大小: tiny / base / small / medium / large-v3
WHISPER_MODEL_SIZE=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
# 模型缓存目录（默认 ~/.cache/faster-whisper-models）
# WHISPER_MODEL_DIR=

# ----- 未来支持 -----
# MINIMAX_API_KEY=sk-your-key-here
# GLM_API_KEY=sk-your-key-here
